{
  "name": "vnus-agent",
  "version": "1.0.0",
  "description": "Vnus AI Desktop Agent",
  "author": "Vnus AI",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start":           "electron .",
    "dev":             "electron . --dev",
    "build":           "electron-builder",
    "build:win":       "electron-builder --win",
    "build:mac":       "electron-builder --mac",
    "build:linux":     "electron-builder --linux",
    "postinstall":     "electron-builder install-app-deps",
    "install-browser": "playwright install chromium --with-deps"
  },
  "dependencies": {
    "playwright":      "^1.45.0",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "ai.vnus.agent",
    "productName": "Vnus Agent",
    "asar":        true,
    "icon":        "assets/icon.png",
    "directories": {
      "output":         "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md}",
      "!**/node_modules/*/{test,__tests__,tests,example,examples}",
      "!**/node_modules/.bin"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "VnusAgent-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon":     "assets/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "VnusAgent-${version}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon":     "assets/icon.png",
      "category": "Utility",
      "artifactName": "VnusAgent-${version}.${ext}"
    },
    "nsis": {
      "oneClick":                           false,
      "perMachine":                         false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall":           true,
      "createDesktopShortcut":              true,
      "createStartMenuShortcut":            true,
      "shortcutName":                       "Vnus Agent"
    },
    "publish": {
      "provider":     "github",
      "releaseType":  "release"
    }
  }
}
